{
  "name": "farmbot-agent",
  "version": "0.1.0",
  "description": "Agent-native CLI and MCP server for controlling FarmBot hardware",
  "type": "module",
  "license": "MIT",
  "author": "Kieran Klaassen",
  "repository": {
    "type": "git",
    "url": "https://github.com/kieranklaassen/farmbot-agent"
  },
  "keywords": [
    "farmbot",
    "mcp",
    "cli",
    "agent",
    "agriculture",
    "iot",
    "model-context-protocol"
  ],
  "bin": {
    "farmbot": "./dist/cli.js",
    "farmbot-mcp": "./dist/mcp.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "commander": "^13.1.0",
    "farmbot": "^15.9.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
